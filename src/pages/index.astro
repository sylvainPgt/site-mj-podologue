---
import Layout from '../layouts/Layout.astro';

const contact = {
	name: 'Marie-Julie Castelle',
	job: 'Pédicure-podologue D.E.',
	phoneDisplay: '06 47 09 86 22',
	phoneHref: 'tel:+33647098622',
	doctolibHref:
		'https://www.doctolib.fr/pedicure-podologue/toulouse/marie-julie-castelle/booking/motives?source=profile',
	email: 'castellepodologue@gmail.com',
	addressLine1: '20 place Occitane',
	addressLine2: '31000 Toulouse',
	access: 'Métro Jean Jaurès, au-dessus du centre commercial Saint-Georges',
	hours: 'Du lundi au vendredi, de 8h à 20h',
};

const healthCenter = {
	name: 'Maison de Santé Pluriprofessionnelle Occitane',
	logoSrc: '/images/msp-occitane.png',
	description:
		"Le cabinet fait partie de la Maison de Santé Pluriprofessionnelle Occitane, située place Occitane à Toulouse, dans un environnement de soins pluriprofessionnel au coeur du centre-ville.",
};

const keyInfos = [
	{
		label: 'Téléphone',
		title: contact.phoneDisplay,
		text: 'Prise de rendez-vous par téléphone.',
	},
	{
		label: 'Horaires',
		title: 'Lundi au vendredi',
		text: 'Consultations de 8h à 20h.',
	},
	{
		label: 'Consultations',
		title: 'Cabinet et domicile',
		text: 'Accueil sur rendez-vous.',
	},
	{
		label: 'Adresse',
		title: `${contact.addressLine1}, ${contact.addressLine2}`,
		text: 'Toulouse centre, à proximité du métro Jean Jaurès.',
	},
];

const services = ['Soins de pédicurie', 'Semelles orthopédiques', 'Soins au cabinet et à domicile'];

const consultationItems = [
	'Soins au cabinet',
	'Soins à domicile',
	'Du lundi au vendredi, de 8h à 20h',
	'Cabinet situé au centre-ville de Toulouse',
];

const nationalDiplomas = [
	{
		year: '2025',
		title: 'D.I.U. Posture Équilibre et Locomotion',
		organization: 'Université Toulouse 3 - Paul Sabatier',
	},
];

const continuingEducation = [
	{
		year: '2019',
		title: 'Formation en K-Taping',
		organization: 'Connaissance & Évolution',
	},
	{
		year: '2019',
		title: 'Diplôme de posturologie',
		organization: 'Connaissance & Évolution',
	},
	{
		year: '2017',
		title: 'Formation en réflexologie',
		organization: 'Luc Fournion - Cours et formations',
	},
	{
		year: '2016',
		title: 'Formation en orthoplastie',
		organization: 'Connaissance & Évolution',
	},
	{
		year: '2016',
		title: 'Formation de thérapie manuelle',
		organization: 'Institut de Formation aux Métiers du Sport et de la Santé (IFM2S)',
	},
	{
		year: '2015',
		title: 'Formation en thérapie manuelle',
		organization: 'Institut de Formation aux Métiers du Sport et de la Santé (IFM2S)',
	},
	{
		year: '2014',
		title: 'Formation en K-Taping',
		organization: 'Académie de K-Taping',
	},
	{
		year: '2013',
		title: 'Formation en K-Taping',
		organization: 'Académie de K-Taping',
	},
];

const primaryCtaClass =
	'inline-flex items-center justify-center rounded-full bg-[#cb5b75] px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-[#b24a63] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#cb5b75] focus-visible:ring-offset-2';

const secondaryCtaClass =
	'inline-flex items-center justify-center rounded-full border border-[#d7b2bc] bg-white px-6 py-3.5 text-sm font-semibold text-[#473640] transition hover:border-[#cb5b75] hover:text-[#cb5b75] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#cb5b75] focus-visible:ring-offset-2';

const headerLinkClass =
	'inline-flex items-center rounded-full border border-[#ead1d9] bg-white px-4 py-2 text-sm font-medium text-[#5d4953] transition hover:border-[#cb5b75] hover:text-[#cb5b75] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#cb5b75] focus-visible:ring-offset-2';

const infoLinkClass =
	'font-medium text-[#3f2f37] underline decoration-[#d7b2bc] underline-offset-4 transition hover:text-[#cb5b75] hover:decoration-[#cb5b75] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#cb5b75] focus-visible:ring-offset-2';

const infoLinkLargeClass =
	'font-semibold text-[#3f2f37] underline decoration-[#d7b2bc] underline-offset-4 transition hover:text-[#cb5b75] hover:decoration-[#cb5b75] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#cb5b75] focus-visible:ring-offset-2';
---

<Layout
	title="Marie-Julie Castelle | Pédicure-podologue à Toulouse"
	description="Cabinet de pédicurie-podologie à Toulouse centre. Soins au cabinet et à domicile, semelles orthopédiques, sur rendez-vous."
>
	<main class="overflow-hidden">
		<section class="bg-[linear-gradient(180deg,#fff8f8_0%,#fff4f6_100%)]">
			<div class="mx-auto max-w-7xl px-6 py-6 lg:px-8">
				<header class="flex flex-col gap-4 border-b border-[#efdbe1] pb-5 md:flex-row md:items-center md:justify-between">
					<div class="flex items-center gap-4">
						<div class="flex h-14 w-14 items-center justify-center overflow-hidden rounded-full bg-[#cb5b75]/10">
							<img src="/images/logo-foot-right.png" alt="Logo du cabinet" class="h-10 w-10 object-contain" />
						</div>
						<div>
							<p class="text-sm font-medium tracking-[0.18em] text-[#a25569] uppercase">Cabinet de pédicurie-podologie</p>
							<p class="mt-1 text-lg font-semibold text-[#3f2f37]">{contact.name}</p>
							<p class="text-sm text-[#7a6670]">{contact.job}</p>
						</div>
					</div>
					<a href={contact.phoneHref} class={headerLinkClass}>
						Téléphone : {contact.phoneDisplay}
					</a>
				</header>

				<div class="grid gap-12 py-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-18">
					<div>
						<p class="text-base font-medium text-[#8e5969]">Cabinet de pédicurie-podologie à Toulouse centre</p>
						<h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-[#3f2f37] sm:text-5xl">
							Cabinet de pédicurie-podologie de {contact.name}
						</h1>
						<p class="mt-6 max-w-2xl text-lg leading-8 text-[#5f4b55]">
							Le cabinet assure des soins de pédicurie, la réalisation de semelles orthopédiques, ainsi que des consultations
							au cabinet et à domicile. Il exerce au sein de la Maison de Santé Pluriprofessionnelle Occitane. Les rendez-vous
							sont proposés du lundi au vendredi, de 8h à 20h.
						</p>

						<div class="mt-8 flex flex-col gap-4 sm:flex-row">
							<a
								href={contact.doctolibHref}
								target="_blank"
								rel="noreferrer"
								class={primaryCtaClass}
							>
								Prendre rendez-vous
							</a>
							<a
								href={contact.phoneHref}
								class={secondaryCtaClass}
							>
								Appeler le cabinet
							</a>
						</div>
					</div>

					<div class="relative">
						<div class="absolute -right-8 -top-8 hidden h-32 w-32 rounded-full bg-[#efc6d1] blur-3xl lg:block"></div>
						<div class="overflow-hidden rounded-[2rem] border border-white/80 bg-white p-3 shadow-[0_24px_70px_rgba(135,72,93,0.12)]">
							<img
								src="/images/hero-foot.jpg"
								alt="Photographie d'un pied"
								class="h-full min-h-[320px] w-full rounded-[1.5rem] object-cover"
							/>
						</div>
					</div>
				</div>

				<div class="grid gap-4 pb-16 sm:grid-cols-2 xl:grid-cols-4">
					{keyInfos.map((item) => (
						<div class="rounded-[1.75rem] border border-[#efdae0] bg-white p-6 shadow-[0_16px_45px_rgba(135,72,93,0.07)]">
							<p class="text-sm font-medium text-[#9d6070]">{item.label}</p>
							<p class="mt-3 text-lg font-semibold text-[#3f2f37]">{item.title}</p>
							<p class="mt-2 text-sm leading-6 text-[#65525b]">{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-18 lg:px-8">
			<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
				<div>
					<p class="text-sm font-semibold tracking-[0.2em] text-[#cb5b75] uppercase">Maison de santé</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-[#3f2f37] sm:text-4xl">
						Le cabinet exerce au sein de la {healthCenter.name}
					</h2>
					<p class="mt-5 max-w-2xl leading-8 text-[#5f4b55]">{healthCenter.description}</p>
				</div>

				<div class="overflow-hidden rounded-[2rem] border border-[#e7d7cd] bg-white p-6 shadow-[0_22px_60px_rgba(135,72,93,0.08)]">
					<img
						src={healthCenter.logoSrc}
						alt="Logo de la Maison de Santé Pluriprofessionnelle Occitane"
						class="w-full rounded-[1.5rem] object-contain"
					/>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-7xl px-6 py-18 lg:px-8">
			<div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
				<div>
					<p class="text-sm font-semibold tracking-[0.2em] text-[#cb5b75] uppercase">Prestations</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-[#3f2f37] sm:text-4xl">Actes proposés</h2>
					<p class="mt-5 max-w-xl leading-7 text-[#60505a]">
						Le cabinet propose des soins de pédicurie, des semelles orthopédiques, ainsi que des consultations au cabinet et
						à domicile.
					</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-3">
					{services.map((service) => (
						<article class="rounded-[1.75rem] border border-[#efdae0] bg-[#fffafb] p-6 shadow-[0_18px_50px_rgba(135,72,93,0.06)]">
							<p class="text-sm font-medium text-[#9d6070]">Prestation</p>
							<h3 class="mt-3 text-xl font-semibold text-[#3f2f37]">{service}</h3>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-[#fff7f8]">
			<div class="mx-auto max-w-7xl px-6 py-18 lg:px-8">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold tracking-[0.2em] text-[#cb5b75] uppercase">Parcours et formations</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-[#3f2f37] sm:text-4xl">
						Diplômes nationaux, universitaires et formations complémentaires
					</h2>
					<p class="mt-5 leading-8 text-[#5f4b55]">
						Le parcours de formation de {contact.name} associe diplôme universitaire et formations complémentaires en posture,
						locomotion, thérapie manuelle, orthoplastie, réflexologie, posturologie et K-Taping.
					</p>
				</div>

				<div class="mt-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
					<article class="rounded-[2rem] border border-[#ebd7dd] bg-white p-8 shadow-[0_20px_55px_rgba(135,72,93,0.08)]">
						<p class="text-sm font-semibold tracking-[0.18em] text-[#cb5b75] uppercase">Diplômes nationaux et universitaires</p>
						<div class="mt-6 space-y-5">
							{nationalDiplomas.map((item) => (
								<div class="rounded-[1.5rem] bg-[#fff7f8] p-5">
									<p class="text-sm font-semibold text-[#a35a6d]">{item.year}</p>
									<h3 class="mt-2 text-xl font-semibold text-[#3f2f37]">{item.title}</h3>
									<p class="mt-2 leading-7 text-[#5f4b55]">{item.organization}</p>
								</div>
							))}
						</div>
					</article>

					<article class="rounded-[2rem] border border-[#ebd7dd] bg-white p-8 shadow-[0_20px_55px_rgba(135,72,93,0.08)]">
						<p class="text-sm font-semibold tracking-[0.18em] text-[#cb5b75] uppercase">Autres formations</p>
						<div class="mt-6 space-y-4">
							{continuingEducation.map((item) => (
								<div class="flex gap-4 rounded-[1.5rem] bg-[#fff7f8] p-5">
									<div class="min-w-14 text-sm font-semibold text-[#a35a6d]">{item.year}</div>
									<div>
										<h3 class="text-lg font-semibold text-[#3f2f37]">{item.title}</h3>
										<p class="mt-1 leading-7 text-[#5f4b55]">{item.organization}</p>
									</div>
								</div>
							))}
						</div>
					</article>
				</div>
			</div>
		</section>

		<section id="contact" class="bg-[#fbf1f4]">
			<div class="mx-auto grid max-w-7xl gap-10 px-6 py-18 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:items-start">
				<div>
					<p class="text-sm font-semibold tracking-[0.2em] text-[#cb5b75] uppercase">Informations pratiques</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-[#3f2f37] sm:text-4xl">Consultations et contact</h2>
					<p class="mt-5 max-w-2xl leading-7 text-[#5f4b55]">
						Le cabinet reçoit au centre-ville de Toulouse, sur rendez-vous, pour des consultations au cabinet et à domicile.
					</p>

					<ul class="mt-6 space-y-4 text-base leading-7 text-[#5f4b55]">
						{consultationItems.map((item) => (
							<li class="flex gap-3">
								<span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[#cb5b75]"></span>
								<span>{item}</span>
							</li>
						))}
					</ul>

					<div class="mt-8 max-w-xl rounded-[2rem] border border-[#e7cad3] bg-[#fffafb] p-7 shadow-[0_20px_55px_rgba(135,72,93,0.08)]">
							<p class="text-sm font-medium text-[#9d6070]">Contact</p>
							<a href={contact.phoneHref} class={`mt-2 block text-2xl ${infoLinkLargeClass}`}>
								{contact.phoneDisplay}
							</a>
							<p class="mt-2 text-sm text-[#65525b]">Du lundi au vendredi, de 8h à 20h.</p>
							<div class="mt-6 grid gap-5 sm:grid-cols-2">
								<div>
									<p class="text-sm font-medium text-[#9d6070]">E-mail</p>
									<a href={`mailto:${contact.email}`} class={`mt-1 block text-base ${infoLinkClass}`}>
										{contact.email}
									</a>
								</div>
								<div>
									<p class="text-sm font-medium text-[#9d6070]">Rendez-vous</p>
									<a
										href={contact.doctolibHref}
										target="_blank"
										rel="noreferrer"
										class={`mt-1 block text-base ${infoLinkClass}`}
									>
										Prendre rendez-vous en ligne sur Doctolib
									</a>
								</div>
							</div>
					</div>
				</div>

				<div class="overflow-hidden rounded-[2.25rem] border border-[#ead1d9] bg-white p-3 shadow-[0_28px_80px_rgba(135,72,93,0.12)]">
					<div class="px-3 pb-4 pt-3">
						<p class="text-sm font-medium text-[#9d6070]">Adresse et accès</p>
						<p class="mt-2 text-base leading-7 text-[#5f4b55]">
							Le cabinet est situé au {contact.addressLine1}, {contact.addressLine2}, sur la place Occitane, au-dessus du centre
							commercial Saint-Georges, en plein centre-ville de Toulouse.
						</p>
						<p class="mt-3 text-base leading-7 text-[#5f4b55]">{contact.access}.</p>
					</div>
					<iframe
						title="Carte du cabinet de Marie-Julie Castelle à Toulouse"
						src="https://www.google.com/maps?q=20+place+Occitane+31000+Toulouse&output=embed"
						class="h-[360px] w-full rounded-[1.5rem] border-0"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
					></iframe>
					<div class="px-2 pb-2 pt-5">
						<p class="text-sm font-medium text-[#9d6070]">Plan d'accès</p>
						<a
							href="https://www.google.com/maps/search/?api=1&query=20+place+Occitane+31000+Toulouse"
							target="_blank"
							rel="noreferrer"
							class={`${secondaryCtaClass} mt-5`}
						>
							Ouvrir l’itinéraire
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
